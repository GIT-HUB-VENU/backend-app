<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/styles.css">
    <title>Document</title>
</head>
<body>
    <h2>Products Admin Page</h2>
    <a href="/products/add">Add Product</a>
    <ol>
    <% products.forEach(product => { %>
    <li><div class="boxProducts">
          <!--<img src="<%= product.image %>" width="300px" alt="Product 1"> -->
          <ul>
            <li >Product Name : <%= product.name %></li>
            <li >Description : <%= product.desc %></li>
            <li >Price : $<%= product.price %></li>
            <a href="/products/<%= product._id %>/edit">Edit</a>
            <a href="/products/<%= product._id %>/delete">Delete</a>
          </ul>
        </div>
    </li>
     <% }) %>
     <ol>
</body>
</html>