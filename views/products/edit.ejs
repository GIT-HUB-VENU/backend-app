<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <h2>Edit Product Form</h2>
    <form action="/products/<%= product._id %>/save" method="POST">
        <input type="text" name="name" placeholder="Product Name" value="<%= product.name %>"><br>
        <input type="text" name="desc" placeholder="Product Description" value="<%= product.desc %>"><br>
        <input type="number" name="price" placeholder="Product Price" value="<%= product.price %>"><br>
        <input type="text" name="image" placeholder="Image URL" accept="image/*" value="<%= product.image %>"><br>
        <button>Save</button>
    </form>
</body>
</html>